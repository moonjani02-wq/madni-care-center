# ---- Local development (optional) ----
# Vite dev server proxies /api to http://localhost:8080 — usually leave API URL unset.

# VITE_API_BASE_URL=http://localhost:8080

# ---- Production build ----
# Create .env.production (see .env.production.example):
#
# 1) Same machine / reverse proxy: often leave VITE_API_BASE_URL unset if /api is proxied to the backend.
# 2) API on another host: set full origin, no trailing slash:
#    VITE_API_BASE_URL=https://api.yourdomain.com
#
# GitHub Pages “project” site (URL has /repo-name/):
#    VITE_BASE=/repo-name/
