# Copy to .env.production before `npm run build` (do not commit real secrets).
#
# Subpath hosting (e.g. GitHub Pages project site https://user.github.io/repo/):
# VITE_BASE=/repo/

# Public API URL when the shop is not served from the same origin as server.ps1 (no trailing slash):
# VITE_API_BASE_URL=https://your-api.example.com
